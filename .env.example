# Attenova – copy to .env and set values. Never commit .env.

# Required
SECRET_KEY=your-secret-key-at-least-50-chars

# Optional – default: True (set False in production)
DEBUG=True

# Comma-separated hosts (e.g. .localhost,127.0.0.1,attenova.example.com)
ALLOWED_HOSTS=

# CORS – allow all origins (default: same as DEBUG; set True only if needed)
# CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# CORS_ALLOW_ALL_ORIGINS=False
# CSRF – trusted origins for cross-origin POST (set same as CORS origins)
# CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Production security and logging
# LOG_LEVEL=INFO
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=False
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# SECURE_HSTS_PRELOAD=False
# USE_X_FORWARDED_PROTO=True

# Default DB: sqlite3 (default), postgresql, or mysql
ATTENOVA_DB_ENGINE=sqlite3
# For SQLite (only when ATTENOVA_DB_ENGINE=sqlite3)
# SQLITE_DB_NAME=db.sqlite3

# For PostgreSQL default DB (when ATTENOVA_DB_ENGINE=postgresql)
# ATTENOVA_DB_NAME=attenova_staging
# ATTENOVA_DB_USER=attenovauser
# ATTENOVA_DB_PASSWORD=
# ATTENOVA_DB_HOST=165.22.222.58
# ATTENOVA_DB_PORT=5432
# ATTENOVA_DB_CONN_MAX_AGE=0

# For MySQL default DB (when ATTENOVA_DB_ENGINE=mysql)
# ATTENOVA_DB_NAME=attenova  (or DEFAULT_DB_* for backward compatibility)
# ATTENOVA_DB_USER=
# ATTENOVA_DB_PASSWORD=
# ATTENOVA_DB_HOST=localhost
# ATTENOVA_DB_PORT=3306

# ESSL biometric DB – only set if you use ESSL integration
# ESSL_DB_NAME=
# ESSL_DB_USER=
# ESSL_DB_PASSWORD=
# ESSL_DB_HOST=
# ESSL_DB_PORT=3306
# ESSL_DB_CONN_MAX_AGE=30

# ESSL sync tuning
# ESSL_DEVICE_LOGS_TABLE=DeviceLogs_2_2026
# ESSL_LOG_DEVICE_IDS=3,9
# ESSL_SYNC_BATCH_SIZE=5000
# ESSL_SYNC_MAX_BATCHES=20

# Optional
# LANGUAGE_CODE=en-us
# TIME_ZONE=UTC
# STATIC_URL=static/
# MEDIA_URL=media/
# MEDIA_ROOT=media

# Docker Compose
# Default DB: fully from .env (ATTENOVA_DB_ENGINE, SQLITE_DB_NAME or DEFAULT_DB_*).
# For SQLite in Docker use SQLITE_DB_NAME=data/db.sqlite3 so the DB persists in the volume.
# Biometric (ESSL): set the connection values above only where the integration is enabled.
# Optional: APP_PORT=8000, COMPOSE_APP_CONTAINER_NAME=attenova-web
# Gunicorn (when running in Docker): GUNICORN_WORKERS=4, GUNICORN_THREADS=2

# Workplace AI assistant (OpenAI). Omit OPENAI_API_KEY to disable server-side assistant (503 from stream endpoint).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# AI_ASSISTANT_ENABLED=true
# AI_ASSISTANT_MAX_USER_MESSAGE_CHARS=6000
# AI_ASSISTANT_RATE_LIMIT_PER_MINUTE=20

# Frontend: show assistant FAB when true (or in dev). Matches optional production rollout.
# VITE_ENABLE_AI_ASSISTANT=true

# Landing “Book a demo” – inbox for form notifications (optional; default in Django settings).
# DEMO_BOOKING_INBOX=akashyadav181198@gmail.com

# Redis (used for cache/sessions/celery; in Docker default is redis://redis:6379/0)
# REDIS_URL=redis://localhost:6379/0
# REDIS_PORT=6379
# COMPOSE_REDIS_CONTAINER_NAME=attenova-redis
